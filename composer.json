{
    "name": "andydefer/laravel-indexer",
    "description": "A powerful and flexible indexing system for Laravel with Eloquent support, n-gram and metaphone tokenization, and advanced search capabilities.",
    "autoload": {
        "psr-4": {
            "AndyDefer\\LaravelIndexer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AndyDefer\\LaravelIndexer\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Andy Kani",
            "email": "andykanidimbu@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "laravel/framework": "^12.0|^13.0|^14.0|^15.0",
        "andydefer/laravel-repository": "^2.10.4",
        "andydefer/laravel-directive": "^3.55.4",
        "andydefer/jsonl-cache": "^0.3.11",
        "andydefer/laravel-logger": "^3.9.3",
        "andydefer/inverted-index-search": "^0.3.3"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.0|^12.0",
        "mockery/mockery": "^1.6",
        "laravel/pint": "^1.29"
    }
}
